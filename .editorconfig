# =============================================================================
# JUANET Enterprise SaaS Platform - EditorConfig Configuration
# Target: Multi-developer, Cross-platform Consistency (Laravel & Frontend Stack)
# =============================================================================

# This is the top-most EditorConfig file in this project
root = true

# -----------------------------------------------------------------------------
# 1. GLOBAL DEFAULT STANDARDS
# -----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# -----------------------------------------------------------------------------
# 2. BACKEND PROGRAMMING LANGUAGES (PHP)
# -----------------------------------------------------------------------------
[*.php]
indent_size = 4
# PSR-12 / PER Coding Style 2.0 standards alignment

# -----------------------------------------------------------------------------
# 3. FRONTEND PROGRAMMING LANGUAGES (JS / TS)
# -----------------------------------------------------------------------------
[*.{js,jsx,ts,tsx}]
indent_size = 2

# -----------------------------------------------------------------------------
# 4. DATA DESCRIPTORS & CONFIGURATIONS (JSON / XML)
# -----------------------------------------------------------------------------
[*.json]
indent_size = 2

[*.xml]
indent_size = 2

# -----------------------------------------------------------------------------
# 5. MARKUP, STYLESHEETS & GRAPHICS
# -----------------------------------------------------------------------------
[*.{html,css,scss}]
indent_size = 2

# -----------------------------------------------------------------------------
# 6. CONFIGURATION AS CODE & ORCHESTRATION (YAML / TOML / ENV)
# -----------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# -----------------------------------------------------------------------------
# 7. INFRASTRUCTURE & CONTAINER DEPLOYMENTS (DOCKER / SHELL / SQL)
# -----------------------------------------------------------------------------
[{Dockerfile,*.dockerfile}]
indent_style = space
indent_size = 4

[*.sh]
indent_size = 4

[*.sql]
indent_size = 4

# -----------------------------------------------------------------------------
# 8. MARKDOWN DOCUMENTATION (Prevent breaking list and spacing formats)
# -----------------------------------------------------------------------------
[*.md]
indent_size = 2
trim_trailing_whitespace = false
