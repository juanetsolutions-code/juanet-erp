###############################################################################
# JUANET Enterprise SaaS Platform - Environment Configuration Template
# Target: Laravel 12 / PHP 8.4 / Supabase PostgreSQL / Redis / MinIO
###############################################################################

# =============================================================================
# 1. APPLICATION CONFIGURATION
# =============================================================================
APP_NAME="JUANET Enterprise"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# =============================================================================
# 2. LOGGING SUBSYSTEM
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# =============================================================================
# 3. DATABASE CONFIGURATION (Supabase PostgreSQL / Relational DB Engine)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_READ_HOST=127.0.0.1
DB_WRITE_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=juanet_platform
DB_USERNAME=postgres
DB_PASSWORD=your_secure_db_password

# =============================================================================
# 4. REDIS CONFIGURATION (Cache, Session, Queue, and Rate Limiting)
# =============================================================================
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# 5. CACHE ENGINE
# =============================================================================
CACHE_STORE=redis

# =============================================================================
# 6. QUEUE CONCURRENCY
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# 7. SESSION MANAGEMENT
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# 8. REAL-TIME BROADCASTING
# =============================================================================
BROADCAST_CONNECTION=log

# =============================================================================
# 9. FILESYSTEM STORES
# =============================================================================
FILESYSTEM_DISK=s3

# =============================================================================
# 10. AWS S3 / MINIO OBJECT STORAGE CONFIGURATION
# =============================================================================
AWS_ACCESS_KEY_ID=juanet_local_key
AWS_SECRET_ACCESS_KEY=juanet_local_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=juanet-local-bucket
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# =============================================================================
# 11. MAIL SERVER (Mailpit SMTP Mock and Production Routing)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@juanet.io"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# 12. FRONTEND VITE INTERFACES
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# =============================================================================
# 13. MULTI-TENANT DOMAIN ARCHITECTURE
# =============================================================================
TENANCY_MODE=multi_db
TENANCY_CENTRAL_DOMAIN=juanet.io
TENANCY_DEFAULT_LOCALE=en

# =============================================================================
# 14. SECURITY & STATE ENFORCEMENT
# =============================================================================
SANCTUM_STATEFUL_DOMAINS="juanet.io,*.juanet.io"
SESSION_SECURE_COOKIE=false
WEBHOOK_SECRET="juanet_enterprise_secret_key"

# =============================================================================
# 15. AUTOMATED UTILITIES (Scheduler and Workers)
# =============================================================================
SCHEDULER_ENABLED=true
QUEUE_WORKERS=default,high,low

# =============================================================================
# 16. LARAVEL HORIZON SERVICE TUNING
# =============================================================================
HORIZON_PREFIX=juanet-horizon:

# =============================================================================
# 17. FEATURE FLAGS SUBSYSTEM
# =============================================================================
FEATURE_AI=true
FEATURE_BILLING=true
FEATURE_API=true
FEATURE_AUDIT=true
FEATURE_NOTIFICATIONS=true

# =============================================================================
# 18. THIRD-PARTY API INTEGRATIONS (Placeholders)
# =============================================================================
# OpenAI Service Suite
OPENAI_API_KEY=your_openai_api_key_here

# Stripe Payment Infrastructure
STRIPE_KEY=pk_test_placeholder
STRIPE_SECRET=sk_test_placeholder

# Google Identity OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft Business OAuth 2.0
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# Twilio Communications System
TWILIO_SID=your_twilio_sid_here
TWILIO_TOKEN=your_twilio_token_here
