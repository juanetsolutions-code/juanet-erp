# ==============================================================================
# JUANET EOS ENTERPRISE PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

APP_NAME="JUANET Enterprise SaaS Platform"
APP_ENV=production
APP_KEY= # Generate using: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# PostgreSQL Relational Storage Cluster Configuration
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=juanet_production
DB_USERNAME=juanet_db_user
DB_PASSWORD= # Specify secure production password

# High-Performance Session, Cache, & Queue Stores (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD= # Specify secure Redis password
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Storage buckets & AWS S3-compatible configuration
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID= # MinIO or S3 root user ID
AWS_SECRET_ACCESS_KEY= # MinIO or S3 root user password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=juanet-production-bucket
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000

# Outgoing Mail trap/server SMTP settings
MAIL_MAILER=smtp
MAIL_HOST= # Production SMTP Mail server
MAIL_PORT=587
MAIL_USERNAME= # Mail username
MAIL_PASSWORD= # Mail password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Safaricom M-PESA Daraja Integration Settings
MPESA_ENV=production # sandbox or production
MPESA_CONSUMER_KEY= # Daraja Portal Consumer Key
MPESA_CONSUMER_SECRET= # Daraja Portal Consumer Secret
MPESA_SHORTCODE= # Daraja Portal Paybill / Buygoods shortcode
MPESA_PASSKEY= # Daraja Portal Online Passkey
MPESA_INITIATOR_NAME= # Daraja B2C Initiator Username
MPESA_INITIATOR_PASSWORD= # Daraja B2C Initiator Password

# Google Gemini Core AI Integration
GEMINI_API_KEY= # Server-side Google AI API Key

# Supabase Auth Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY= # Anon key for auth redirection rules
